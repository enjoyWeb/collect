  "tips": [
    {
      "title": "如何查找正确的选择器？",
      "steps": [
        "1. 打开浏览器开发者工具（按 F12）",
        "2. 右键点击要点击的元素",
        "3. 选择【检查】或【Inspect】",
        "4. 在 HTML 代码中找到该元素",
        "5. 复制 class 或 id 属性作为选择器"
      ]
    },
    {
      "title": "如何测试选择器是否正确？",
      "steps": [
        "1. 打开包含目标元素的网页",
        "2. 按 F12 打开开发者工具",
        "3. 进入【Console】标签",
        "4. 输入: document.querySelector('你的选择器')",
        "5. 如果返回元素对象，说明选择器正确"
      ]
    },
    {
      "title": "如何设置合理的延迟时间？",
      "steps": [
        "1. 先用较大的延迟（如 3000ms）测试",
        "2. 如果运行成功，逐步减少延迟时间",
        "3. 找到最小可行延迟（页面仍能正确加载）",
        "4. 在该基础上再加 500ms 作为安全边距",
        "5. 不同网站可能需要不同延迟时间"
      ]
    }
  ],
  "commonIssues": [
    {
      "problem": "扩展找不到元素，显示【未找到选择器】",
      "solutions": [
        "检查选择器语法是否正确",
        "使用开发者工具验证选择器",
        "确认元素在 DOM 中存在",
        "尝试增加延迟时间",
        "使用更具体的选择器"
      ]
    },
    {
      "problem": "链接无法打开",
      "solutions": [
        "检查 URL 格式是否正确（要包含 http:// 或 https://）",
        "确认网址是否有效且可访问",
        "检查网络连接是否正常",
        "查看浏览器控制台中的错误信息"
      ]
    },
    {
      "problem": "自动化运行到中间停止了",
      "solutions": [
        "查看运行日志找到失败的具体链接",
        "检查该链接的选择器是否正确",
        "尝试增加延迟时间",
        "检查网络是否中断",
        "重新开始运行"
      ]
    }
  ]
}
