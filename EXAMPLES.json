  "selectorExamples": [
    {
      "type": "按 Class 选择",
      "html": "<button class=\"submit-btn\">提交</button>",
      "selector": ".submit-btn"
    },
    {
      "type": "按 ID 选择",
      "html": "<button id=\"confirm-btn\">确认</button>",
      "selector": "#confirm-btn"
    },
    {
      "type": "按标签类型",
      "html": "<button>点击</button>",
      "selector": "button"
    },
    {
      "type": "按属性值",
      "html": "<button data-action=\"claim\">领取</button>",
      "selector": "[data-action=\"claim\"]"
    },
    {
      "type": "多个 Class",
      "html": "<div class=\"btn btn-primary\">立即登陆</div>",
      "selector": ".btn.btn-primary"
    },
    {
      "type": "组合选择器",
      "html": "<form><button class=\"submit-btn\">提交</button></form>",
      "selector": "form button.submit-btn"
    },
    {
      "type": "属性包含",
      "html": "<button onclick=\"start()\">开始</button>",
      "selector": "button[onclick*=\"start\"]"
    },
    {
      "type": "第一个元素",
      "html": "<div><button>1</button><button>2</button></div>",
      "selector": "button:first-child"
    }
  ],
